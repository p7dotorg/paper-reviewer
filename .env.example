# Required
OPENROUTER_API_KEY=sk-or-...

# ── Paper review models (all via OpenRouter) ────────────────────────────────
CLASSIFY_MODEL=openai/gpt-4o-mini
REVIEWER_MODEL=deepseek/deepseek-v4-flash
TOOL_MODEL=openai/gpt-4o-mini
FIGURE_MODEL=google/gemini-2.5-flash
STRUCTURED_MODEL=openai/gpt-4o-mini
SYNTHESIZE_MODEL=deepseek/deepseek-v4-flash
JUDGE_MODEL=openai/gpt-4o

# ── Dataset research loop (drl) ─────────────────────────────────────────────
DRL_SCORE_MODEL=openai/gpt-4o-mini
DRL_BUNDLE=bundle
# KAGGLE_USERNAME=       # optional — raises Kaggle scan limits
# KAGGLE_KEY=

# ── LangSmith tracing (optional) ────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=paper-reviewer

# ── paper7 API (optional — used for paper search/fetch) ─────────────────────
# PAPER7_API_URL=http://localhost:8000
